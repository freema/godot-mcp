{
  "name": "@satelliteoflove/godot-mcp",
  "version": "3.23.1",
  "description": "MCP server that gives AI assistants eyes and hands in the Godot editor: scene editing, input injection, deterministic game-time control, and live runtime state for agent-driven playtesting",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "godot-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "addon",
    "server.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satelliteoflove/godot-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/satelliteoflove/godot-mcp/issues"
  },
  "homepage": "https://github.com/satelliteoflove/godot-mcp#readme",
  "scripts": {
    "build": "tsc && npm run copy-addon",
    "copy-addon": "tsx scripts/copy-addon.ts",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "dev": "tsc --watch",
    "dev:cli": "nodemon --exec \"tsx src/cli.ts\" --ext ts --watch src",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-docs": "tsx scripts/generate-docs.ts",
    "eval": "tsx evals/run-evals.ts",
    "test:coverage": "vitest run --coverage",
    "test:protocol": "tsx scripts/protocol-smoke.ts"
  },
  "keywords": [
    "godot",
    "godot4",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "ai-agents",
    "claude",
    "game-development",
    "game-testing",
    "gdscript"
  ],
  "author": "Christopher Childress",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.8",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "mcpName": "io.github.satelliteoflove/godot-mcp"
}
